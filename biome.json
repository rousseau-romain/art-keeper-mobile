{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!dist",
      "!android",
      "!ios",
      "!node_modules",
      "!assets",
      "!src/lib/api/generated",
      "!**/*.d.ts"
    ]
  },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2 },
  "javascript": {
    "formatter": { "quoteStyle": "double" },
    "globals": ["__DEV__"]
  },
  "linter": {
    "enabled": true,
    "domains": { "react": "recommended" },
    "rules": {
      "preset": "recommended",
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "react-native": {
                "importNames": ["Text"],
                "message": "Import the themed `Text` from \"@/shared/ui\" instead of \"react-native\"."
              }
            },
            "patterns": [
              {
                "group": ["../**"],
                "message": "Use the \"@/\" path alias instead of a parent-relative \"../\" import."
              }
            ]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  },
  "overrides": [
    {
      "includes": ["src/shared/ui/text/Text.tsx"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ]
}
