{
  "expo": {
    "name": "art-keeper",
    "slug": "art-keeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "artkeeper",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.artkeeper.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ArtKeeper uses the camera to photograph street art you submit.",
        "NSPhotoLibraryUsageDescription": "ArtKeeper lets you pick photos of street art from your library.",
        "NSLocationWhenInUseUsageDescription": "ArtKeeper uses your location to pin pieces on the map and find art near you."
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.artkeeper.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ArtKeeper uses Face ID to unlock your saved session."
        }
      ],
      "expo-localization",
      "expo-image-picker",
      "expo-location",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
