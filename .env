# Enable Expo Router's web modal system (vaul-based sheets). Without it, the web
# Stack renders `presentation: "formSheet"` routes (the (formsheet) group) as
# full-screen cards; with it, they render as content-sized sheets that honor
# `sheetAllowedDetents: "fitToContents"`. Read by Expo's Metro web config only —
# native iOS/Android sheets are unaffected. Restart Metro after changing this.
EXPO_UNSTABLE_WEB_MODAL=1
