{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/serena-guard.sh\"",
            "statusMessage": "Checking code-search routing (Serena)"
          }
        ]
      }
    ]
  }
}
